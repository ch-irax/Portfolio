# ========== Portfolio Backend Environment Variables ==========
# Copy this file to .env and fill in your actual values

# Server Configuration
PORT=5000
NODE_ENV=production

# Frontend URL (for CORS configuration)
FRONTEND_URL=https://your-portfolio-frontend.vercel.app

# ========== MongoDB Configuration ==========
# Get your connection string from MongoDB Atlas
# 1. Go to MongoDB Atlas dashboard
# 2. Click "Connect" on your "portfolio" cluster
# 3. Choose "Drivers" → "Node.js"
# 4. Copy the connection string
# 5. Replace USERNAME, PASSWORD, and cluster details below

MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@portfolio.xxxxx.mongodb.net/portfolio?retryWrites=true&w=majority

# ========== Email Configuration (Optional) ==========
# If you want email notifications when contact form is submitted:
# 1. Go to: https://myaccount.google.com/apppasswords
# 2. Generate an app password (requires 2FA enabled)
# 3. Copy the 16-character password

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-16-char-app-password

# Note: Leave EMAIL_* empty if you don't want email notifications
